# ─── Database ────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=nexus
MYSQL_PASSWORD=nexuspassword

# ─── JWT ─────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=NexusProjectManagement2024SecretKeyForJWTTokenGenerationMustBeLongEnough256Bits

# ─── Spring Profile ───────────────────────────────────────────────
# Options: default | dev | prod
SPRING_PROFILE=default

# ─── Frontend ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api
